# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=True

# Generate a new, random secret key for production and never share it!
SECRET_KEY=your-very-long-and-secure-random-secret-key-here

# Replace with your server's IP address and domain names (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com,www.yourdomain.com

# The exact URLs of your frontend to allow API requests
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
FRONTEND_BASE_URL=https://yourdomain.com

# Database Settings
DB_NAME=bids_awards
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Email Settings (Optional: For system notifications/forgot password)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
